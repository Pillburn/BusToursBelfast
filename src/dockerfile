# Build stage
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copy the main API project file and restore dependencies
COPY ["src/Api/ToursApp.Api.csproj", "src/Api/"]
COPY ["src/Application/ToursApp.Application.csproj", "src/Application/"]
COPY ["src/Infrastructure/ToursApp.Infrastructure.csproj", "src/Infrastructure/"]

# Restore all projects (including referenced ones)
RUN dotnet restore "src/Api/ToursApp.Api.csproj"

# Copy all source code
COPY . .

# Build and publish the API project
WORKDIR "/src/src/Api"
RUN dotnet publish "ToursApp.Api.csproj" -c Release -o /app/publish

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "ToursApp.Api.dll"]