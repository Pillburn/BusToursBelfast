# Build stage
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /source

# Copy csproj files preserving the folder structure
COPY src/Api/ToursApp.Api.csproj src/Api/
COPY src/Application/ToursApp.Application.csproj src/Application/
COPY src/Infrastructure/ToursApp.Infrastructure.csproj src/Infrastructure/

# Restore dependencies
RUN dotnet restore "src/Api/ToursApp.Api.csproj"

# Copy all source code
COPY src/ src/

# Build and publish
RUN dotnet publish "src/Api/ToursApp.Api.csproj" -c Release -o /app/publish --no-restore

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "ToursApp.Api.dll"]